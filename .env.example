# === Nexus Configuration ===

# Anthropic API key (leave empty for mock mode)
ANTHROPIC_API_KEY=

# Tavily Search API key (leave empty for mock mode)
TAVILY_API_KEY=

# Telegram (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Reddit (leave empty to disable)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Twitter/X (leave empty to disable)
TWITTER_BEARER_TOKEN=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Monitoring
POLL_INTERVAL_MINUTES=10
ALERT_RELEVANCE_THRESHOLD=7.0
